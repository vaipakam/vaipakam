{
  "name": "vaipakam-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Vaipakam — decentralised P2P lending + borrowing + NFT rental. Workspace root for the apps/ + packages/ layout.",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "pnpm --filter @vaipakam/defi dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "alpha:dev": "pnpm --filter @vaipakam/alpha dev",
    "alpha:build": "pnpm --filter @vaipakam/alpha build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bufferutil",
      "esbuild",
      "keccak",
      "sharp",
      "utf-8-validate",
      "workerd"
    ],
    "overrides": {
      "axios": "^1.15.2",
      "ws@^8.0.0": "^8.20.1",
      "brace-expansion@^5.0.0": "^5.0.6"
    }
  }
}
