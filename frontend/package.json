{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "tsx scripts/generate-sitemap.ts && tsx scripts/inject-seo-meta.ts",
    "lint": "eslint .",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "npm run build && wrangler deploy",
    "translate": "tsx scripts/translate-i18n.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.1",
    "connectkit": "^1.9.2",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.4",
    "react-is": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "valtio": "^1.13.2",
    "viem": "^2.48.4",
    "wagmi": "^2.19.5"
  },
  "overrides": {
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.1",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.4",
    "wrangler": "^4.84.1"
  }
}
