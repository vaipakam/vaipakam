# Frontend public config. Only values prefixed with VITE_ are exposed to
# the browser bundle — never put private keys or secrets in here.
# Copy this file to `.env.local` (git-ignored) and fill in real values.
#
# Each supported chain has a triplet:
#   VITE_<CHAIN>_RPC_URL            — read endpoint (Alchemy/Infura URL
#                                     strongly recommended; free public
#                                     RPCs are rate-limited and silently
#                                     drop log queries on cold start).
#   VITE_<CHAIN>_DIAMOND_ADDRESS    — deployed Diamond proxy address.
#   VITE_<CHAIN>_DEPLOY_BLOCK       — block the Diamond was created at.
#                                     Starting log scans here (not 0)
#                                     keeps cold-start queries fast.
#                                     Find it in contracts/broadcast/
#                                     DeployDiamond.s.sol/<chainId>/run-latest.json.




VITE_ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# ── Base Sepolia (Phase 1 canonical-VPFI testnet) ─────────────────────────
VITE_BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
VITE_BASE_SEPOLIA_DIAMOND_ADDRESS=
VITE_BASE_SEPOLIA_DEPLOY_BLOCK=
# Per-facet verify-link targets (Security section). Source-of-truth:
# contracts/deployments/base-sepolia/addresses.json.
VITE_BASE_SEPOLIA_ESCROW_IMPL=
VITE_BASE_SEPOLIA_RISK_FACET_ADDRESS=
VITE_BASE_SEPOLIA_PROFILE_FACET_ADDRESS=

# Default chain when no wallet is connected or wallet is on an unsupported
# chain. 84532 = Base Sepolia.
VITE_DEFAULT_CHAIN_ID=84532

# Block-range per eth_getLogs call. RPC providers disagree on limits:
#   Alchemy free:  10     (default — works everywhere, slow on cold start)
#   Infura free:   1000
#   publicnode:    10000
# Raise this after switching to a less-restrictive RPC.
VITE_LOG_INDEX_CHUNK=10000

# ── Sepolia (Phase 1 mirror-VPFI testnet, peered with Base Sepolia) ──────
VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
VITE_SEPOLIA_DIAMOND_ADDRESS=
VITE_SEPOLIA_DEPLOY_BLOCK=
VITE_SEPOLIA_ESCROW_IMPL=
VITE_SEPOLIA_RISK_FACET_ADDRESS=
VITE_SEPOLIA_PROFILE_FACET_ADDRESS=

# ── Arbitrum Sepolia (Phase 1 mirror-VPFI, peered with Base Sepolia) ─────
VITE_ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
VITE_ARBITRUM_SEPOLIA_DIAMOND_ADDRESS=
VITE_ARBITRUM_SEPOLIA_DEPLOY_BLOCK=

# ── OP Sepolia (Phase 1 mirror-VPFI, peered with Base Sepolia) ───────────
VITE_OPTIMISM_SEPOLIA_RPC_URL=https://opt-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
VITE_OPTIMISM_SEPOLIA_DIAMOND_ADDRESS=
VITE_OPTIMISM_SEPOLIA_DEPLOY_BLOCK=

# ── Polygon Amoy (Phase 1 mirror-VPFI, peered with Base Sepolia) ─────────
VITE_POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
VITE_POLYGON_AMOY_DIAMOND_ADDRESS=
VITE_POLYGON_AMOY_DEPLOY_BLOCK=

# ── BNB Smart Chain Testnet (Phase 1 mirror-VPFI, peered with Base Sepolia) ─
# Native-BNB mode for the buy adapter (treated as native-gas the same
# way Sepolia/OP/Arb adapters treat ETH). Pay in tBNB; the canonical
# Base receiver still quotes wei-per-VPFI on its side.
VITE_BNB_TESTNET_RPC_URL=https://bnb-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
VITE_BNB_TESTNET_DIAMOND_ADDRESS=
VITE_BNB_TESTNET_DEPLOY_BLOCK=
VITE_BNB_TESTNET_METRICS_FACET_ADDRESS=
VITE_BNB_TESTNET_ESCROW_IMPL=
VITE_BNB_TESTNET_RISK_FACET_ADDRESS=
VITE_BNB_TESTNET_PROFILE_FACET_ADDRESS=
VITE_BNB_TESTNET_VPFI_BUY_ADAPTER=

VITE_WALLETCONNECT_PROJECT_ID=<ReownProjectID>

VITE_HF_WATCHER_ORIGIN=https://alerts.vaipakam.com

# Push Protocol channel address — the wallet that owns the Vaipakam
# Push channel (created on https://app.push.org/). Public info; safe
# to commit. Used by the Alerts page to render a one-click
# "Subscribe on Push" deep link to
# `https://app.push.org/channels/<address>` so users land directly
# on the right channel page in their Push wallet.
VITE_PUSH_CHANNEL_ADDRESS=0x6F5847A0CA1F2cB1bbEf944124cE5995988a1D6b

# Telegram bot configuration belongs in the Cloudflare Worker, NOT here.
# - The frontend never reads the bot token; only the worker calls
#   Telegram's API on the user's behalf.
# - Vite drops any `.env` key without a `VITE_` prefix at build time, so
#   `TG_BOT_TOKEN` here would be silently ignored. If you'd added
#   `VITE_TG_BOT_TOKEN`, Vite would inline the secret into the browser
#   bundle — the regression #00003 was filed to prevent.
#
# Configure the bot in the worker instead:
#   ops/hf-watcher/.dev.vars.example   ← local dev template
#   wrangler secret put TG_BOT_TOKEN   ← production (encrypted)
#   wrangler.jsonc `vars.TG_BOT_USERNAME` ← production (plaintext, public)