# Frontend public config. Only values prefixed with VITE_ are exposed to
# the browser bundle — never put private keys or secrets in here.
# Copy this file to `.env.local` (git-ignored) and fill in real values.
#
# ── What lives here vs. in deployments.json ─────────────────────────
#
# This file holds OPERATOR-SPECIFIC config that doesn't change between
# contract deploys: RPC provider URLs (with the operator's API key),
# WalletConnect project ID, default chain, feature flags, etc.
#
# Deployment-artifact addresses (Diamond, escrow impl, every facet,
# LayerZero adapters, VPFI token / mirror, reward OApp, mock token
# addresses, etc.) live in `frontend/src/contracts/deployments.json`,
# which is regenerated from the canonical
# `contracts/deployments/<chain-slug>/addresses.json` files via
#
#   bash contracts/script/exportFrontendDeployments.sh
#
# after every redeploy. So the workflow is:
#
#   1. Deploy contracts on chain X (writes contracts/deployments/<x>/...)
#   2. Run the export script (updates frontend/src/contracts/deployments.json)
#   3. `cd frontend && npm run deploy`  — vite inlines the new addresses
#
# No `.env.local` edits required for an address change.
#
# ── Per-chain RPC URLs ──────────────────────────────────────────────
#
# Free public RPCs are rate-limited and silently drop log queries on
# cold start. Use Alchemy / Infura / drpc URLs for any chain the app
# actually serves. The default fallbacks compiled in for unset chains
# ARE the public RPCs — fine for read-only browsing, broken for
# anything log-intensive.

VITE_ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

VITE_BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
VITE_ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
VITE_OPTIMISM_SEPOLIA_RPC_URL=https://opt-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
VITE_BNB_TESTNET_RPC_URL=https://bnb-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Optional — only set when you want to override the public-RPC default
# the chain registry compiles in. Each unset URL falls back to the
# chain's public RPC.
# VITE_BASE_RPC_URL=
# VITE_ARBITRUM_RPC_URL=
# VITE_OPTIMISM_RPC_URL=
# VITE_BNB_RPC_URL=
# VITE_POLYGON_ZKEVM_RPC_URL=
# VITE_POLYGON_ZKEVM_CARDONA_RPC_URL=
# VITE_ANVIL_RPC_URL=

# ── App-level config ────────────────────────────────────────────────

# Default chain when no wallet is connected or wallet is on an unsupported
# chain. 84532 = Base Sepolia.
VITE_DEFAULT_CHAIN_ID=84532

# Block-range per eth_getLogs call. RPC providers disagree on limits:
#   Alchemy free:  10     (default — works everywhere, slow on cold start)
#   Infura free:   1000
#   publicnode:    10000
# Raise this after switching to a less-restrictive RPC.
VITE_LOG_INDEX_CHUNK=10000

# WalletConnect / Reown project ID. Get one at https://cloud.reown.com.
VITE_WALLETCONNECT_PROJECT_ID=<ReownProjectID>

# HF-watcher Cloudflare Worker origin. Frontend's HF-alert subscribe
# button POSTs to this origin's `/subscribe` endpoint.
VITE_HF_WATCHER_ORIGIN=https://alerts.vaipakam.com

# Push Protocol channel address — the wallet that owns the Vaipakam
# Push channel (created on https://app.push.org/). Public info; safe
# to commit. Used by the Alerts page to render a one-click
# "Subscribe on Push" deep link to
# `https://app.push.org/channels/<address>` so users land directly
# on the right channel page in their Push wallet.
VITE_PUSH_CHANNEL_ADDRESS=0x6F5847A0CA1F2cB1bbEf944124cE5995988a1D6b

# ── Feature flags ───────────────────────────────────────────────────

# 2026-05-01 — diagnostics drawer master flag. When set to the literal
# string "false" the floating Report-Issue drawer (LifeBuoy button +
# slide-over panel) doesn't mount at all — server-side error capture
# still runs in the background regardless. Default behaviour (unset
# OR any value other than "false") is to render the drawer, so
# existing deploys are unchanged. Flip this to "false" once
# server-side capture has been observed working in production.
VITE_DIAG_DRAWER_ENABLED=true

# T-042 — public-visibility gate for the admin Knobs & Switches
# dashboard at `/admin` (and the in-app reference at `/admin/docs`).
# Default-true: anyone can navigate to the dashboard and see every
# governance-tunable parameter's current value, hard bound, and
# recommended operational zone — same transparency posture as Aave /
# Compound / Maker. Flip to "false" on a deploy where parameter
# visibility itself is restricted (e.g. industrial fork; pre-launch
# tuning window). With the flag off, both routes hard-redirect to
# home; Phase 4 will refine this to "redirect unless admin wallet
# connected" so signers can still reach the cockpit privately.
VITE_ADMIN_DASHBOARD_PUBLIC=true

# 2026-05-01 — server-side error-capture kill switch. Defaults OFF
# (frontend never POSTs to /diag/record unless this is the literal
# string "true"). The worker endpoint + D1 schema have shipped, but
# until the operator has run through DeploymentRunbook §8d (apply
# the migration, deploy the worker, smoke-test the endpoint), keep
# this OFF so a frontend deploy can't flood an unprepared endpoint.
# Flip to "true" once §8d is complete.
VITE_DIAG_RECORD_ENABLED=false

# 2026-05-01 — optional app version stamp surfaced in the server-side
# error-capture rows. Set in CI to the build commit hash so triage
# can correlate errors with releases. Unset = null in the recorded row.
# VITE_APP_VERSION=

# ── Out of scope ────────────────────────────────────────────────────
#
# Telegram bot configuration belongs in the Cloudflare Worker, NOT here.
# - The frontend never reads the bot token; only the worker calls
#   Telegram's API on the user's behalf.
# - Vite drops any `.env` key without a `VITE_` prefix at build time, so
#   `TG_BOT_TOKEN` here would be silently ignored. If you'd added
#   `VITE_TG_BOT_TOKEN`, Vite would inline the secret into the browser
#   bundle — the regression #00003 was filed to prevent that.
#
# Configure the bot in the worker instead:
#   ops/hf-watcher/.dev.vars.example   ← local dev template
#   cd ops/hf-watcher && wrangler secret put TG_BOT_TOKEN
#                                      ← production (encrypted)
#   wrangler.jsonc `vars.TG_BOT_USERNAME` ← production (plaintext, public)
