# Cloudflare Workers static-assets header rules for alpha02.
# https://developers.cloudflare.com/workers/static-assets/headers/
#
# Copied verbatim from `public/` to `dist/` by Vite at build time;
# Cloudflare serves it as deploy-time routing metadata — nothing here
# ships as code to the browser.
#
# TIGHTER than apps/defi's file on purpose: alpha02 loads no Google
# Analytics and no external fonts, so script-src carries no third-party
# hosts and font-src needs no Google origins. The permissive
# `connect-src https: wss:` is inherent to a crypto frontend — RPC
# endpoints are env-configurable hosts, the indexer/agent Workers and
# the realtime push channel (wss://indexer.vaipakam.com/ws/chain/:id)
# are separate origins, and WalletConnect relays are third-party. Pin
# narrower only if the RPC set is ever frozen.
#
# `unsafe-inline`/`unsafe-eval` in script-src mirror defi (wallet SDK
# constraints); tightening to nonces is a follow-up hardening pass —
# do not loosen further without review.
#
# Safe-App embed support: `frame-ancestors` allows Safe's dapp-browser
# origins (alpha02 registers the Safe connector). `X-Frame-Options` is
# deliberately omitted — it can't express an allowlist; modern browsers
# enforce `frame-ancestors`, which is the superset.
# `Cross-Origin-Resource-Policy: cross-origin` lets the Safe parent
# frame (a different origin) read our resources.
#
# frame-src allows the WalletConnect verify iframe the wallet-connect
# handshake renders.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: https:; connect-src 'self' https: wss:; frame-src 'self' https://verify.walletconnect.com https://verify.walletconnect.org; worker-src 'self' blob:; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self' https://app.safe.global https://*.safe.global; upgrade-insecure-requests

# SPA entry point — served for every non-asset path via wrangler.jsonc
# `not_found_handling: single-page-application`. Force revalidation on
# every load so a deploy can never pin a client to stale JS that signs
# calldata against stale ABIs/addresses. The bundles themselves stay
# long-cached via /assets/* because Vite emits content-hashed names.

/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Immutable static assets (content-hashed filenames).

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Wallet-gated, per-user surfaces — never index. Header-level noindex
# so even a crawler that doesn't execute JS sees the policy (the SPA
# fallback serves index.html for these paths; SeoMeta's
# <meta name="robots"> only exists after hydration). Deliberately NOT
# robots.txt-Disallowed: a Disallow blocks crawling but not reference-
# only indexing of the URL — noindex requires the fetch to be seen.
# Every rule has a `/*` sibling: the router also renders trailing-
# slash and deeper variants, and _headers matching is exact
# (Codex #1309 r7). Keep in sync with SeoMeta.tsx + generate-seo.mjs.

/positions
  X-Robots-Tag: noindex
/positions/*
  X-Robots-Tag: noindex
/claims
  X-Robots-Tag: noindex
/claims/*
  X-Robots-Tag: noindex
/vault
  X-Robots-Tag: noindex
/vault/*
  X-Robots-Tag: noindex
/activity
  X-Robots-Tag: noindex
/activity/*
  X-Robots-Tag: noindex
/settings
  X-Robots-Tag: noindex
/settings/*
  X-Robots-Tag: noindex
/faucet
  X-Robots-Tag: noindex
/faucet/*
  X-Robots-Tag: noindex

# Childless PUBLIC routes — the route itself is indexable, but any
# deeper path (`/borrow/anything`) is NotFound in the router: the SPA
# fallback still serves the index shell with a 200, so a non-executing
# crawler would otherwise index a soft 404 (Codex #1309 r8). `/nft` is
# deliberately ABSENT from this list: `/nft/:tokenId` children are
# valid, indexable pages (SeoMeta noindexes the malformed ones after
# hydration). `/positions/*` already carries noindex in the
# wallet-gated block above.

/borrow/*
  X-Robots-Tag: noindex
/lend/*
  X-Robots-Tag: noindex
/rent/*
  X-Robots-Tag: noindex
/offers/*
  X-Robots-Tag: noindex
/desk/*
  X-Robots-Tag: noindex
/vpfi/*
  X-Robots-Tag: noindex
/help/*
  X-Robots-Tag: noindex

# SPA aliases (App.tsx Navigate routes). The redirect only happens
# after JS runs, so a non-executing crawler fetching an alias gets
# the index shell — noindex ALL of them (Codex #1309 r1 + r2): the
# per-user-surface aliases (/dashboard, /manage, /loans*, /claim*,
# /vault-assets, /history) because their targets are never indexed,
# and the public-surface aliases (/earn, /offer-book, /trade,
# /terminal, /vpfi-vault, /nft-rental) because the alias URL is a
# duplicate of an indexable canonical target — the canonical route
# is the ONLY indexable address for that content.

/dashboard
  X-Robots-Tag: noindex
/dashboard/*
  X-Robots-Tag: noindex
/manage
  X-Robots-Tag: noindex
/manage/*
  X-Robots-Tag: noindex
/loans
  X-Robots-Tag: noindex
/loans/*
  X-Robots-Tag: noindex
/app/loans/*
  X-Robots-Tag: noindex
/claim
  X-Robots-Tag: noindex
/claim/*
  X-Robots-Tag: noindex
/claim-center
  X-Robots-Tag: noindex
/claim-center/*
  X-Robots-Tag: noindex
/vault-assets
  X-Robots-Tag: noindex
/vault-assets/*
  X-Robots-Tag: noindex
/history
  X-Robots-Tag: noindex
/history/*
  X-Robots-Tag: noindex
/earn
  X-Robots-Tag: noindex
/earn/*
  X-Robots-Tag: noindex
/offer-book
  X-Robots-Tag: noindex
/offer-book/*
  X-Robots-Tag: noindex
/trade
  X-Robots-Tag: noindex
/trade/*
  X-Robots-Tag: noindex
/terminal
  X-Robots-Tag: noindex
/terminal/*
  X-Robots-Tag: noindex
/vpfi-vault
  X-Robots-Tag: noindex
/vpfi-vault/*
  X-Robots-Tag: noindex
/nft-rental
  X-Robots-Tag: noindex
/nft-rental/*
  X-Robots-Tag: noindex
