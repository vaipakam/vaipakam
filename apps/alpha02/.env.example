# alpha02 runtime configuration. Copy to .env.local and fill in.
# All contract addresses come from @vaipakam/contracts deployments.json —
# never from env.

# Per-chain RPC URLs (fall back to public endpoints when unset).
VITE_BASE_SEPOLIA_RPC_URL=
VITE_ARBITRUM_SEPOLIA_RPC_URL=
VITE_BNB_TESTNET_RPC_URL=
VITE_ETHEREUM_RPC_URL=
VITE_BASE_RPC_URL=
VITE_ARBITRUM_RPC_URL=
VITE_OPTIMISM_RPC_URL=
VITE_BNB_RPC_URL=

# OPTIONAL per-chain WebSocket RPC URLs. When set, the live-update layer
# subscribes to new blocks (eth_subscribe) so transactions reflect in the
# UI near-instantly; when unset it falls back to HTTP block polling. Env
# key defaults to the RPC key with _RPC_URL -> _WSS_URL, shown here.
# (e.g. dRPC: swap https:// for wss:// on the same path.)
VITE_BASE_SEPOLIA_WSS_URL=
VITE_ARBITRUM_SEPOLIA_WSS_URL=

# Default chain for reads when disconnected/unsupported (chainId).
VITE_DEFAULT_CHAIN_ID=84532

# WalletConnect Cloud project id — WalletConnect pairing is disabled
# when unset (extension wallets still work).
VITE_WALLETCONNECT_PROJECT_ID=

# Indexer worker origin. When unset, list pages show an honest
# "couldn't load" state instead of fake-empty markets.
VITE_INDEXER_ORIGIN=https://indexer.vaipakam.com
