{
  "name": "@vaipakam/alpha02",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Naive-user-first redesign of the Vaipakam connected app — alpha02.vaipakam.com. Intent-first guided flows, Basic/Advanced mode, light/dark theme, mobile-first.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b --noEmit",
    "build": "tsc -b tsconfig.build.json && vite build",
    "preview": "vite preview",
    "deploy": "REQUIRE_INDEXER_ORIGIN=1 pnpm run build && wrangler deploy",
    "e2e": "playwright test",
    "e2e:typecheck": "tsc -p e2e/tsconfig.json --noEmit",
    "i18n:template": "tsx scripts/export-i18n-template.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.1",
    "@vaipakam/contracts": "workspace:*",
    "@vaipakam/i18n": "workspace:*",
    "@vaipakam/lib": "workspace:*",
    "connectkit": "^1.9.2",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-i18next": "^17.0.4",
    "lightweight-charts": "^5",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "viem": "^2.48.4",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.15.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.4",
    "wrangler": "^4.84.1"
  }
}
