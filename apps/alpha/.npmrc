# `legacy-peer-deps=true` is required for `npm install` / `npm ci` to succeed
# while `connectkit@1.9.x` declares `react@^17 || ^18` as a peer and our
# app is on React 19. ConnectKit is runtime-compatible with React 19
# (hooks + context, no React 18-specific APIs) — the peer declaration just
# hasn't been bumped upstream yet. Revisit once ConnectKit tags a release
# that lists React 19 in its peer dependencies, at which point this line
# can come out.
legacy-peer-deps=true
