{
  // Vaipakam first-party autonomous keeper Worker.
  //
  // Cron-driven only (no fetch handler). Stage 3 PR2 of the
  // Worker split — see docs/DesignsAndPlans/Stage3WorkerSplitPlan.md
  // for the full classification and migration sequencing.
  //
  // Owns: HF watcher loop + autonomous liquidation submission +
  // HF-band-downgrade Telegram / Push alerts + daily oracle
  // snapshot signer (moved from agent in the Stage 3 architectural-
  // rebalance commit; co-located with the existing
  // KEEPER_PRIVATE_KEY consumer so the signing key lives on
  // exactly one Worker, per staging plan §2). Future scope (per
  // §7 of the Stage 3 plan): off-chain offer matcher.
  //
  // Distinct from the public reference keeper-bot at the sibling
  // `vaipakam-keeper-bot` repo (different deploy target, different
  // trust assumptions). That repo follows its own ABI sync + CI
  // workflow per the Phase 9.A docs in CLAUDE.md.
  //
  // Custom domain: not user-facing. Worker name `vaipakam-keeper`
  // is the deploy-switch identifier and stays post-cutover.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vaipakam-keeper",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-23",
  "compatibility_flags": ["nodejs_compat"],

  // Cron — every minute. The watcher is internally tick-rate-aware:
  // each tick sweeps `getChainConfigs(env)` round-robin and bails
  // early on chains that already have notify_state at the same band
  // since the previous tick. A "* * * * *" schedule matches the
  // existing ops/hf-watcher cadence; tighter schedules don't help
  // (HF reads are per-tick rate-limited inside the watcher).
  "triggers": {
    "crons": ["* * * * *"],
  },

  // D1 binding — the same `vaipakam-alerts-db` database the
  // indexer + agent Workers also bind. Tables this Worker reads:
  //   - `thresholds`        (per-user-loan HF bands; written by frontend)
  //   - `link_codes`        (Telegram handshake codes; agent writes)
  //   - `notify_state`      (per-user notify dedupe; this Worker writes)
  //   - `loan_index_*`      (active-loan rows; written by indexer; this
  //                          Worker reads to enumerate live loans)
  // Cross-Worker D1 sharing is the deliberate coupling that lets the
  // three Workers stay independent without a message-bus layer
  // (Stage 3 plan §5).
  // D1 binding — `vaipakam-archive` is the STAGING database for
  // the new 3-Worker split (apps/{keeper,indexer,agent}). It's
  // distinct from `vaipakam-alerts-db` which the legacy
  // `vaipakam-hf-watcher` Worker (primary infra) writes to and
  // is intentionally untouched until staging is fully validated.
  // See docs/DesignsAndPlans/CloudflareStagingDeployPlan.md §3
  // for the staging-vs-primary D1 split.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "vaipakam-archive",
      "database_id": "3cffebf5-b652-4da7-953c-9e1d143ad2fe",
    },
  ],

  // T-078 — the keeper's secrets are read from the account-level
  // Cloudflare Secrets Store (store `vaipakam-credentials`, id
  // 1e66429d0fa24aa38a27bc05b7bcf63e), not per-Worker
  // `wrangler secret put`. Each binding is resolved asynchronously
  // once per cron tick in `resolveEnv()` (src/env.ts). Local
  // `wrangler dev` needs the same secrets created WITHOUT the
  // `--remote` flag.
  //
  // `RPC_ZKEVM` is omitted (Polygon zkEVM out of scope); `RPC_POLYGON`
  // / `RPC_POLYGON_AMOY` are agent-only. `TG_BOT_TOKEN` must still be
  // created in the store (the `VaipakamBot` token) before deploy.
  "secrets_store_secrets": [
    { "binding": "RPC_BASE",          "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "RPC_BASE" },
    { "binding": "RPC_ETH",           "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "RPC_ETH" },
    { "binding": "RPC_ARB",           "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "RPC_ARB" },
    { "binding": "RPC_OP",            "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "RPC_OP" },
    { "binding": "RPC_BNB",           "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "RPC_BNB" },
    { "binding": "RPC_SEPOLIA",       "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "RPC_SEPOLIA" },
    { "binding": "RPC_BASE_SEPOLIA",  "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "RPC_BASE_SEPOLIA" },
    { "binding": "RPC_ARB_SEPOLIA",   "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "RPC_ARB_SEPOLIA" },
    { "binding": "RPC_OP_SEPOLIA",    "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "RPC_OP_SEPOLIA" },
    { "binding": "RPC_BNB_TESTNET",   "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "RPC_BNB_TESTNET" },
    { "binding": "TG_BOT_TOKEN",      "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "TG_BOT_TOKEN" },
    { "binding": "PUSH_CHANNEL_PK",   "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "PUSH_CHANNEL_PK" },
    { "binding": "ZEROEX_API_KEY",    "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "ZEROEX_API_KEY" },
    { "binding": "ONEINCH_API_KEY",   "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "ONEINCH_API_KEY" },
    { "binding": "KEEPER_PRIVATE_KEY", "store_id": "1e66429d0fa24aa38a27bc05b7bcf63e", "secret_name": "KEEPER_PRIVATE_KEY" },
  ],

  // Operator-managed vars (non-secret config — plain `vars`):
  //   - KEEPER_ENABLED   — 'true' arms the autonomous liquidation /
  //                        matcher / liquidity-confidence submit paths.
  //   - TG_BOT_USERNAME  — public Telegram bot handle.
  //   - REWARD_REMIT_ENABLED — 'true' arms the #776 reward-budget remit pass
  //     (only after the keeper EOA is authorized on-chain). Optional knobs:
  //     REWARD_REMIT_LOOKBACK_DAYS (default 45),
  //     REWARD_REMIT_LANE_CAP (wei, default 100000e18 — see #918).
  //   - FRONTEND_ORIGIN, LIQ_* / SPLIT_* / PARTIAL_LIQ_* tuning knobs
  //     (see src/env.ts) — all optional, sensible defaults.
  "vars": {
    // Public Telegram bot handle (the @-name from BotFather). Filled
    // post-provision; the worker accepts an empty string and returns
    // bot_url: null in the handshake response when not configured.
    "TG_BOT_USERNAME": "",
  },

  "observability": {
    "enabled": true,
  },
}
