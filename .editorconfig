# EditorConfig — https://editorconfig.org/
# Standardises basic whitespace / EOL / indent across editors so a
# Windows contributor opening a Solidity file gets the same diff
# shape a Linux contributor would.
#
# Honoured natively by VS Code, JetBrains family, vim/neovim, Helix,
# Sublime, Zed, and most editors via plugin.

root = true

# ----------------------------------------------------------------------
# Defaults — apply to every file unless overridden below
# ----------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# ----------------------------------------------------------------------
# Languages with project-specific style
# ----------------------------------------------------------------------

# Solidity — `forge fmt` uses 4-space indent and 120-col line length.
# Matching here keeps editor + formatter in lockstep so an IDE-format
# action doesn't conflict with the pre-commit `forge fmt --check`.
[*.sol]
indent_style = space
indent_size = 4
max_line_length = 120

# Markdown — trailing whitespace is meaningful (two-space line-break).
# Don't strip it; the pre-commit `trailing-whitespace` hook already
# has the `--markdown-linebreak-ext=md` carve-out for the same reason.
[*.md]
trim_trailing_whitespace = false

# Makefiles MUST use tabs (gmake parses tabs as recipe-line markers).
[Makefile]
indent_style = tab

# ----------------------------------------------------------------------
# Binary / generated — no opinion
# ----------------------------------------------------------------------

# .gas-snapshot is mechanically generated by `forge snapshot`. Don't
# touch its EOL/whitespace shape; it must round-trip bit-identical for
# the snapshot --check workflow to pass.
[*.gas-snapshot]
trim_trailing_whitespace = false
insert_final_newline = false

# JSON / YAML — formatter-stable; keep their own opinions.
[*.{json,yaml,yml}]
indent_size = 2
