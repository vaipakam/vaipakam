# Deployer private key (DO NOT commit .env with real keys).
# Must be the key for DEPLOYER_ADDRESS below — it signs every tx.
PRIVATE_KEY=0x<deployer_private_key>

# Phase-1 (no-governance) 2-EOA topology:
#   DEPLOYER_ADDRESS — short-lived. Signs DeployDiamond + cuts. Holds
#                      nothing after the script's Step-6 handover.
#   ADMIN_ADDRESS    — long-lived. After DeployDiamond completes it holds
#                      ERC-173 ownership + every RBAC role (DEFAULT_ADMIN,
#                      ADMIN, PAUSER, KYC_ADMIN, ORACLE_ADMIN, RISK_ADMIN,
#                      ESCROW_ADMIN). All subsequent admin txs must be
#                      signed by this key.
# If admin == deployer (single-EOA setup, e.g. anvil), the handover is
# a no-op and the single EOA retains everything.
DEPLOYER_ADDRESS=0xb985F8987720C6d76f02909890AA21C11bC6EBCA
ADMIN_ADDRESS=0xF718BaE5e0dc36140F16dAEF73289294c2372030
ADMIN_PRIVATE_KEY=0x<admin_private_key>

# Treasury address
TREASURY_ADDRESS=0xca3E735C593088D2f5ea5AEAa553a6bDaa6E7413

#Lender Address
LENDER_ADDRESS=0xE87319e4F4Cd0A0bD6FF2c087D038AC90d6023Cb

#Borrower Address
BORROWER_ADDRESS=0x3E18999652b1f0dD9f02510A60188935e20bB7B3

# RPC URLs
ANVIL_RPC_URL=http://127.0.0.1:8545
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
OP_SEPOLIA_RPC_URL=https://opt-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
ARB_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Etherscan API key (for contract verification on Sepolia)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

LENDER_PRIVATE_KEY=0x<private_key_for_0xE873...>
BORROWER_PRIVATE_KEY=0x<private_key_for_0x3E18...>


NEW_LENDER_ADDRESS=0x0CE790617db2Aa0B850F0DD4d097bf12BC7Fde05
NEW_LENDER_PRIVATE_KEY=0x<private_key>
NEW_BORROWER_ADDRESS=0xbb8919589B6F261D10D49b991Ac04bE4cd70476C
NEW_BORROWER_PRIVATE_KEY=0x<private_key>
# Per-chain Diamond addresses — scripts dispatch by block.chainid.
BASE_SEPOLIA_DIAMOND_ADDRESS=0xae4A906cF6822EC488a4FF07Fa570c42e8993ddf
SEPOLIA_DIAMOND_ADDRESS=0xc815c2C2B7872a8C9d8f3ffEef612B2517E53632
ARB_SEPOLIA_DIAMOND_ADDRESS=0x8d89Ad168b510d26DAd9CaE3ee2246a8CB6A88D3
OP_SEPOLIA_DIAMOND_ADDRESS=0x8d89Ad168b510d26DAd9CaE3ee2246a8CB6A88D3
POLYGON_AMOY_DIAMOND_ADDRESS=0x8d89Ad168b510d26DAd9CaE3ee2246a8CB6A88D3

# VPFI deploy config (canonical Base Sepolia / mirror on other chains).
VPFI_OWNER=0xb985F8987720C6d76f02909890AA21C11bC6EBCA
VPFI_TREASURY=0xca3E735C593088D2f5ea5AEAa553a6bDaa6E7413
VPFI_INITIAL_MINTER=0xb985F8987720C6d76f02909890AA21C11bC6EBCA

# LayerZero V2 EndpointV2 per chain.
# https://docs.layerzero.network/v2/deployments/deployed-contracts
LZ_ENDPOINT_BASE_SEPOLIA=0x6EDCE65403992e310A62460808c4b910D972f10f
LZ_ENDPOINT_SEPOLIA=0x6EDCE65403992e310A62460808c4b910D972f10f
LZ_ENDPOINT_ARB_SEPOLIA=0x6EDCE65403992e310A62460808c4b910D972f10f
LZ_ENDPOINT_OP_SEPOLIA=0x6EDCE65403992e310A62460808c4b910D972f10f
LZ_ENDPOINT_POLYGON_AMOY=0x6EDCE65403992e310A62460808c4b910D972f10f

# VPFI canonical stack on Base Sepolia (populated by DeployVPFICanonical.s.sol).
BASE_SEPOLIA_VPFI_TOKEN_IMPL=0x08de67696efeeb57bC6187e92371715a03cD4E12
BASE_SEPOLIA_VPFI_TOKEN=0x0D16d09e32515455956b85AAF7978755E8803720
BASE_SEPOLIA_VPFI_OFT_ADAPTER_IMPL=0xFE9B46092Ac34A636CB261A99c98D96cd0b4f796
BASE_SEPOLIA_VPFI_OFT_ADAPTER=0x00122a9d0C4060135E271c2284FfBc27CCB546F9

# VPFI mirror on Sepolia (populated by DeployVPFIMirror.s.sol).
SEPOLIA_VPFI_MIRROR_IMPL=0xC123eb93A716838BC134cCFC01815e4B91F4f1C1
SEPOLIA_VPFI_MIRROR=0x7224DAC2d6837207D23127a34d84A2b6572D4fd8

# VPFI mirror on Arbitrum Sepolia (populated by DeployVPFIMirror.s.sol).
ARB_SEPOLIA_VPFI_MIRROR_IMPL=0x86D3200b6B29fdb9ea6d8d06748bBC9eCE3e87ce
ARB_SEPOLIA_VPFI_MIRROR=0xce30C660949c7A421d459A3C283dbD682b9f79fF

# VPFI mirror on OP Sepolia (populated by DeployVPFIMirror.s.sol).
OP_SEPOLIA_VPFI_MIRROR_IMPL=0x86D3200b6B29fdb9ea6d8d06748bBC9eCE3e87ce
OP_SEPOLIA_VPFI_MIRROR=0xce30C660949c7A421d459A3C283dbD682b9f79fF

# VPFI mirror on Polygon Amoy (populated by DeployVPFIMirror.s.sol).
POLYGON_AMOY_VPFI_MIRROR_IMPL=0x86D3200b6B29fdb9ea6d8d06748bBC9eCE3e87ce
POLYGON_AMOY_VPFI_MIRROR=0xce30C660949c7A421d459A3C283dbD682b9f79fF

# WireVPFIPeers.s.sol — one-shot LZ peer setter, run per (local, remote) pair.
# Works for BOTH the OFT mesh (adapter↔mirror) and the fixed-rate buy mesh
# (VPFIBuyAdapter↔VPFIBuyReceiver). Reverse-direction MUST also be run on
# the remote chain.
# LOCAL_OAPP=<OApp proxy on this chain>
# REMOTE_EID=<LayerZero-eid of remote chain>  (Sepolia=40161, Base Sepolia=40245,
#                                             Arb Sepolia=40231, OP Sepolia=40232,
#                                             Polygon Amoy=40267)
# REMOTE_PEER=<OApp proxy on the remote chain>
LOCAL_OAPP=
REMOTE_EID=
REMOTE_PEER=

# ============================================================
# DeployVPFIBuyReceiver.s.sol (Base only).
# Deploys the UUPS VPFIBuyReceiver and registers it with the Diamond.
# Receiver must be pre-funded with ETH after deploy so it can pay LZ fees
# for BUY_SUCCESS/BUY_FAILED responses + the return OFT send.
# ------------------------------------------------------------
# Populated after running DeployVPFIBuyReceiver.s.sol:
BASE_SEPOLIA_VPFI_BUY_RECEIVER_IMPL=
BASE_SEPOLIA_VPFI_BUY_RECEIVER=
# Optional LZ executor options (hex). Empty is accepted at init; must be
# set (via receiver.setResponseOptions / setOFTSendOptions) before the
# first bridged BUY_REQUEST is served.
VPFI_BUY_RESPONSE_OPTIONS=
VPFI_BUY_OFT_SEND_OPTIONS=

# ============================================================
# DeployVPFIBuyAdapter.s.sol (non-Base mirror chains).
# ------------------------------------------------------------
# LZ eid of the Base receiver (40245 for Base Sepolia, 30184 for Base mainnet).
VPFI_BUY_RECEIVER_EID=40245
# Seconds before a PENDING buy is reclaimable by anyone. 15m default.
VPFI_BUY_REFUND_TIMEOUT_SECONDS=900
# Default LZ options for BUY_REQUEST. Empty is accepted at init but
# must be set (adapter.setBuyOptions) before the first buy.
VPFI_BUY_OPTIONS=
# Payment token per mirror chain. address(0) = native ETH. On Polygon
# Amoy set this to canonical WETH (18 dec, 1:1 ETH).
SEPOLIA_VPFI_BUY_PAYMENT_TOKEN=0x0000000000000000000000000000000000000000
ARB_SEPOLIA_VPFI_BUY_PAYMENT_TOKEN=0x0000000000000000000000000000000000000000
OP_SEPOLIA_VPFI_BUY_PAYMENT_TOKEN=0x0000000000000000000000000000000000000000
POLYGON_AMOY_VPFI_BUY_PAYMENT_TOKEN=
# Populated after running DeployVPFIBuyAdapter.s.sol per chain:
SEPOLIA_VPFI_BUY_ADAPTER_IMPL=
SEPOLIA_VPFI_BUY_ADAPTER=
ARB_SEPOLIA_VPFI_BUY_ADAPTER_IMPL=
ARB_SEPOLIA_VPFI_BUY_ADAPTER=
OP_SEPOLIA_VPFI_BUY_ADAPTER_IMPL=
OP_SEPOLIA_VPFI_BUY_ADAPTER=
POLYGON_AMOY_VPFI_BUY_ADAPTER_IMPL=
POLYGON_AMOY_VPFI_BUY_ADAPTER=

# ============================================================
# ConfigureVPFIBuy.s.sol (Base only).
# Sets the canonical sale rate, caps, enable flag, and ETH price asset.
# ------------------------------------------------------------
# Sale rate: 1 VPFI = 0.001 ETH → 1e15 wei per VPFI.
VPFI_BUY_WEI_PER_VPFI=1000000000000000
# Global (mesh-wide) cap on VPFI sold via the buy program. 2.3M.
VPFI_BUY_GLOBAL_CAP=2300000000000000000000000
# Per-wallet cap. 30k.
VPFI_BUY_PER_WALLET_CAP=30000000000000000000000
# Master enable flag.
VPFI_BUY_ENABLED=true
# Asset whose Diamond-internal ETH price is used for VPFI discount math.
# On Base Sepolia this is WETH.
BASE_SEPOLIA_VPFI_DISCOUNT_ETH_PRICE_ASSET=0x4200000000000000000000000000000000000006

# ============================================================
# ConfigureOracle.s.sol — per-chain wiring of feeds, factory, 0x.
# Each var is resolved as <CHAIN>_<KEY>; missing keys fall back to the
# bare <KEY>. Common values shown for Base Sepolia.
# ------------------------------------------------------------
# WETH contract (Base Sepolia canonical WETH).
BASE_SEPOLIA_WETH_ADDRESS=0x4200000000000000000000000000000000000006
# Uniswap v3 factory (Base Sepolia).
BASE_SEPOLIA_UNISWAP_V3_FACTORY=0x4752ba5DBc23f44D87826276BF6Fd6b1C372aD24
# Chainlink ETH/USD feed (Base Sepolia).
BASE_SEPOLIA_ETH_USD_FEED=0x4aDC67696bA383F43DD60A9e78F2C97Fbbfc7cb1
# Chainlink Denominations library sentinels (chain-agnostic).
BASE_SEPOLIA_USD_DENOMINATOR=0x0000000000000000000000000000000000000348
BASE_SEPOLIA_ETH_DENOMINATOR=0x000000000000000000000000000000000000eEeE
SEPOLIA_USD_DENOMINATOR=0x0000000000000000000000000000000000000348
SEPOLIA_ETH_DENOMINATOR=0x000000000000000000000000000000000000eEeE
ARB_SEPOLIA_USD_DENOMINATOR=0x0000000000000000000000000000000000000348
ARB_SEPOLIA_ETH_DENOMINATOR=0x000000000000000000000000000000000000eEeE
OP_SEPOLIA_USD_DENOMINATOR=0x0000000000000000000000000000000000000348
OP_SEPOLIA_ETH_DENOMINATOR=0x000000000000000000000000000000000000eEeE
POLYGON_AMOY_USD_DENOMINATOR=0x0000000000000000000000000000000000000348
POLYGON_AMOY_ETH_DENOMINATOR=0x000000000000000000000000000000000000eEeE
# L2 sequencer uptime feed (Base Sepolia). Leave unset on L1 testnets.
BASE_SEPOLIA_SEQUENCER_UPTIME_FEED=0xBCF85224fc0756B9Fa45aA7892530B47e10b6433
# 0x Exchange Proxy and its allowance target (HF-based liquidation path).
# Look up current deployment at https://0x.org/docs/introduction/0x-cheat-sheet
BASE_SEPOLIA_ZEROX_PROXY=
BASE_SEPOLIA_ZEROX_ALLOWANCE_TARGET=
# Mainnet-only Chainlink Feed Registry — leave blank on testnets/L2s.
MAINNET_CHAINLINK_REGISTRY=0x47Fb2585D2C56Fe188D0E6ec628a38b74fCeeeDf
# Optional stable-token feed registration. Comma-separated symbols.
# Per symbol set <CHAIN>_<SYMBOL>_FEED.
VPFI_STABLE_FEED_SYMBOLS=USDC
BASE_SEPOLIA_USDC_FEED=0xd30e2101a97dcbAeBCBC04F14C3f624E67A35165

# ============================================================
# ConfigureRewardReporter.s.sol — cross-chain reward plumbing.
# Run per chain. Canonical (Base) also wires the aggregator's expected
# source eids.
# ------------------------------------------------------------
# VaipakamRewardOApp proxy. Deterministic across chains under the CREATE2
# bootstrap (DeployRewardOAppCreate2.s.sol). Populate once, reuse everywhere.
REWARD_OAPP_PROXY=
# LZ eid of THIS chain. Swap per chain.
# 40161 Sepolia · 40245 Base Sepolia · 40231 Arb Sepolia · 40232 OP Sepolia · 40267 Polygon Amoy
LOCAL_EID=
# LZ eid of Base (canonical reward chain). Base Sepolia=40245, Base mainnet=30184.
BASE_EID=40245
# Grace period (seconds) between closeDay and accept-global-report. Default 4h.
REWARD_GRACE_SECONDS=14400
# Comma-separated list of non-Base mirror eids that send reports back to Base.
# Only read when running on the canonical chain.
REWARD_EXPECTED_SOURCE_EIDS=40161,40231,40232,40267

# ============================================================
# SetInteractionLaunch.s.sol — day-0 anchor, SAME on every chain.
# ------------------------------------------------------------
INTERACTION_LAUNCH_TIMESTAMP=
# Optional per-loan cap on VPFI/ETH (1e18-scaled). Leave 0 to skip.
INTERACTION_CAP_VPFI_PER_ETH=0

# ============================================================
# DeployRewardOAppCreate2.s.sol — cross-chain deterministic RewardOApp.
# ------------------------------------------------------------
REWARD_VERSION=v1
REWARD_OWNER=
DIAMOND_ADDRESS=
IS_CANONICAL_REWARD=false
LZ_ENDPOINT=
REPORT_OPTIONS_HEX=0x
BROADCAST_OPTIONS_HEX=0x

# ============================================================
# DeployTimelock.s.sol / TransferAdminToTimelock.s.sol
# ------------------------------------------------------------
# Multi-sig (Gnosis Safe) that is allowed to schedule + cancel
# timelocked operations on the Diamond. Same address is used as
# EXECUTOR by default; set TIMELOCK_EXECUTOR=0x00...00 to allow
# anyone to execute once the delay elapses.
TIMELOCK_PROPOSER=
TIMELOCK_EXECUTOR=0x0000000000000000000000000000000000000000
# Minimum delay in seconds between schedule() and execute(). 48h default.
TIMELOCK_MIN_DELAY=172800

# Per-chain timelock addresses — populated AFTER running DeployTimelock
# on each chain. TransferAdminToTimelock reads these to know where to
# hand off ADMIN_ROLE / ERC-173 ownership.
BASE_SEPOLIA_TIMELOCK_ADDRESS=
BASE_TIMELOCK_ADDRESS=
SEPOLIA_TIMELOCK_ADDRESS=
ARB_SEPOLIA_TIMELOCK_ADDRESS=
OP_SEPOLIA_TIMELOCK_ADDRESS=
POLYGON_AMOY_TIMELOCK_ADDRESS=

# Safety gate — TransferAdminToTimelock refuses to broadcast unless
# this is literally the string "YES". Prevents the handover script
# from running by accident against mainnet.
CONFIRM_HANDOVER=NO