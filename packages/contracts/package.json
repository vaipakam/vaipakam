{
  "name": "@vaipakam/contracts",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Per-facet ABI JSONs + per-chain deployments + typed loaders. Single source of truth consumed by every app in the monorepo (apps/defi, apps/www, apps/agent, apps/keeper, apps/indexer). Mirrored from contracts/ via the export scripts in contracts/script/.",
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "viem": "^2.55.4"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./abis": {
      "types": "./src/abis/index.ts",
      "default": "./src/abis/index.ts"
    },
    "./chain-config": {
      "types": "./src/chain-config.ts",
      "default": "./src/chain-config.ts"
    },
    "./abis/*.json": "./src/abis/*.json",
    "./deployments": {
      "types": "./src/deployments.ts",
      "default": "./src/deployments.ts"
    },
    "./deployments.json": "./src/deployments.json",
    "./_deployments_source.json": "./src/_deployments_source.json"
  }
}
