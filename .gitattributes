# Existing — graphify-out merge driver
graphify-out/graph.json merge=graphify-merge

# ----------------------------------------------------------------------
# EOL normalisation
# ----------------------------------------------------------------------
# Default: store LF in the index AND check out LF on every platform.
# `eol=lf` overrides Git's platform-default checkout-EOL, so Windows
# contributors see LF in their working copy too (not CRLF). This is
# the right shape for a project that ships shell scripts + Solidity:
# a CRLF working copy round-tripping through git would break tooling
# that reads files via the index.
* text=auto eol=lf

# Force LF for files where mismatch is a real bug class
*.sh         text eol=lf
*.bash       text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.json       text eol=lf
*.toml       text eol=lf
*.sol        text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.js         text eol=lf
*.jsx        text eol=lf
*.md         text eol=lf
*.py         text eol=lf
*.txt        text eol=lf
LICENSE      text eol=lf
Makefile     text eol=lf

# ----------------------------------------------------------------------
# Binary — never normalise; never diff as text
# ----------------------------------------------------------------------
# Note on SVG: deliberately NOT marked binary. SVGs are XML text and
# are diffable / mergeable — UI icon + logo edits under apps/defi /
# apps/www are real source we want to see inline diffs for. Image
# editors that emit a single-line "minified" SVG are still text;
# git diff handles them fine.
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pdf        binary
*.zip        binary
*.tar.gz     binary
*.wasm       binary
*.gas-snapshot binary

# ----------------------------------------------------------------------
# Linguist — fix the GitHub language-stats bar
# ----------------------------------------------------------------------
# Vendored deps shouldn't count towards the repo's language mix.
# Submodules (forge-std, openzeppelin-contracts-upgradeable,
# chainlink-local, diamond-3-hardhat) are typically excluded by
# GitHub Linguist anyway, but explicit marking is portable + safer
# against future Linguist behaviour changes.
contracts/lib/forge-std/**                          linguist-vendored
contracts/lib/openzeppelin-contracts-upgradeable/** linguist-vendored
contracts/lib/chainlink-local/**                    linguist-vendored
contracts/lib/diamond-3-hardhat/**                  linguist-vendored

# chainlink-ccip + chainlink-evm are NOT git submodules (they sit
# under contracts/lib/ as tracked subdirectories — likely copied in
# or via `git subtree`). Without explicit linguist-vendored, they
# heavily skew the language stats — Chainlink's `chainlink-evm` and
# `chainlink-ccip` together include thousands of vendor Solidity
# files that are not Vaipakam code.
contracts/lib/chainlink-ccip/** linguist-vendored
contracts/lib/chainlink-evm/**  linguist-vendored

# Per-facet ABI JSONs are mechanically generated — mark as
# generated so Linguist excludes them from the language bar AND so
# `git diff` defaults to summary mode.
packages/contracts/src/abis/**/*.json linguist-generated

# Solidity artefacts (out/) — generated. Already gitignored, but
# defensive.
contracts/out/** linguist-generated

# Audit reports (audits/) — these are documentation of FINDINGS,
# but their language is whatever the auditor wrote in (often
# Markdown + embedded PDF). Mark vendored so Linguist doesn't
# attribute them to the repo's mix.
audits/**/*.pdf  linguist-vendored binary
audits/**/*.md   linguist-documentation
