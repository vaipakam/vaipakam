# Remix compiler artifacts
**/artifacts/
**/artifacts/**

# Remix plugin state folders
deps/
states/

node_modules
dist/

# This is a pnpm workspace (packageManager: pnpm@10.4.1). A stray npm/yarn
# lockfile makes VS Code's package-manager detector report "multiple lockfiles"
# and can desync installs — keep pnpm-lock.yaml the only lockfile in the tree.
package-lock.json
yarn.lock

# Debug info
*.dbg.json
*.tsbuildinfo

# Optional
.env
.env.local
.env.example.example

# Cloudflare Worker local-dev secrets. The `.example` file is
# committed, the populated `.dev.vars` is local-only and contains
# unencrypted secrets (TG_BOT_TOKEN, RPC URLs, aggregator keys).

.wrangler
.dev.vars
**/.dev.vars

# Personal scratchpad — kept on disk for the operator's own notes
# but not committed.
docs/internal/RoughNotes.md
docs/internal/RoughNotes-*.md
# Screenshot / image scratchpad — the operator's reference area; never
# committed. See `feedback_git_add_explicit` (agent memory) for the
# regression this rule guards against (PR #162 round-1).
docs/internal/*.png
docs/internal/*.jpg
docs/internal/*.jpeg
docs/internal/*.gif
docs/internal/*.webp
docs/internal/*.svg

# Claude Code per-machine / per-session runtime state. The
# scheduled_tasks.lock file rewrites every session with a fresh
# sessionId/PID/timestamp, settings.local.json is per-user, and
# worktrees/ holds ephemeral agent worktrees. None of these are
# meaningful across machines.
.claude/
.grok/

graphify-out/
.graphify_*

# Rehearsal artifacts under contracts/deployments/<slug>/.
#
# `addresses.json` and `deployment_source.json` STAY committed — they
# are the canonical "what's live + which commit produced it" record
# every consumer reads from. The rest is transient per-rehearsal
# scratch that accumulates fast and is regenerated on every deploy:
#
#   - .markers/           per-step sentinel files for --resume
#   - .history/           per-step addresses.json snapshots + health logs
#   - addresses.prior-rehearsal.<unix-ts>.json
#                         pre-deploy backups written by --fresh
#
# A multi-rehearsal session writes hundreds of these files; committing
# them would clutter the repo without forensic value (deployment_source.json
# already pins commit→bytecode at deploy time).
contracts/deployments/*/.markers/
contracts/deployments/*/.history/
contracts/deployments/*/addresses.prior-rehearsal.*.json
# `--fresh` (deploy-testnet.sh / deploy-mainnet.sh) archives the
# prior chain state — addresses.json + deployment_source.json +
# .markers + .history + addresses.prior-rehearsal.* — into a single
# timestamped subdirectory under .archive/<ISO-8601>/ before wiping.
# Forensic value only; rebuilds on every --fresh redeploy.
contracts/deployments/*/.archive/

.vscode/

# Generated by apps/www/scripts/generate-sitemap.mjs on every build.
# The `lastmod` date in sitemap.xml and the timestamp comment in
# robots.txt change every build, so committing would create noise.
# The `prebuild` script regenerates them; Vite copies them from
# public/ into dist/ at build time so Cloudflare serves them at the
# site root (/sitemap.xml, /robots.txt).
apps/www/public/sitemap.xml
apps/www/public/robots.txt
# Generated by apps/www/scripts/generate-llms.mjs on every build
# (raw markdown docs + AI-crawler index files).
apps/www/public/docs/
apps/www/public/llms.txt
apps/www/public/llms-full.txt
# Same pattern for alpha02 (apps/alpha02/scripts/generate-seo.mjs).
apps/alpha02/public/sitemap.xml
apps/alpha02/public/robots.txt

# ops/{subgraph,tenderly,lz-watcher} per-chain generated artifacts.
#
# These are deploy-time outputs of contracts/script/export*.sh.
# Each carries a `monorepoCommit` provenance header in its body
# (subgraph) or as a sibling sidecar (tenderly), so the source of
# truth is the commit hash + the export script — committing the
# rendered file is redundant and creates a merge conflict on every
# redeploy (address + startBlock change).
#
# What STAYS committed for these surfaces:
#   - ops/subgraph/subgraph.yaml         the per-chain template
#   - ops/subgraph/abis/Diamond.json     event-ABI bundle
#   - ops/subgraph/abis/_source.json     ABI bundle's commit stamp
#   - ops/tenderly/alerts.yaml           the alert template
ops/subgraph/generated/
ops/tenderly/generated/
ops/lz-watcher/generated/